From e795249083584f4fd4e7264981f587221ef1ff71 Mon Sep 17 00:00:00 2001
From: Pepper Gray <hello@peppergray.xyz>
Date: Sat, 11 Apr 2026 19:33:07 +0200
Subject: [PATCH] adjust audit2why map for python2 and 3

align conditonal python symbols creation and export

fix: #461
Signed-off-by: Pepper Gray <hello@peppergray.xyz>
---
 src/audit2why-py2.map |  5 +++++
 src/audit2why-py3.map |  5 +++++
 src/setup.py          | 16 +++++++++++++---
 3 files changed, 23 insertions(+), 3 deletions(-)
 create mode 100644 src/audit2why-py2.map
 create mode 100644 src/audit2why-py3.map

diff --git a/src/audit2why-py2.map b/src/audit2why-py2.map
new file mode 100644
index 0000000000..249f0beb3b
--- /dev/null
+++ b/src/audit2why-py2.map
@@ -0,0 +1,5 @@
+AUDIT2WHY_2.9 {
+  global:
+    initaudit2why;
+  local: *;
+};
diff --git a/src/audit2why-py3.map b/src/audit2why-py3.map
new file mode 100644
index 0000000000..e99b8d7688
--- /dev/null
+++ b/src/audit2why-py3.map
@@ -0,0 +1,5 @@
+AUDIT2WHY_2.9 {
+  global:
+    PyInit_audit2why;
+  local: *;
+};
diff --git a/src/setup.py b/src/setup.py
index 679ea43f8b..9201448f0e 100644
--- a/src/setup.py
+++ b/src/setup.py
@@ -1,3 +1,13 @@
-#!/usr/bin/python3
+#!/usr/bin/env python

+import sys
 from setuptools import Extension, setup
+
+PY_MAJOR_VERSION = sys.version_info[0]
+
+if PY_MAJOR_VERSION >= 3:
+    audit2why_map = "audit2why-py3.map"
+    description = "SELinux python 3 bindings"
+else:
+    audit2why_map = "audit2why-py2.map"
+    description = "SELinux python 2 bindings"
@@ -8 +18 @@
-    description="SELinux python 3 bindings",
+    description=description,
@@ -16 +26 @@
-                  extra_link_args=['-l:libsepol.a', '-Wl,--version-script=audit2why.map'])
+                  extra_link_args=['-l:libsepol.a', "-Wl,--version-script={}".format(audit2why_map)])

